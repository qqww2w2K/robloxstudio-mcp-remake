			end
			if not (ty < h) then
				break
			end
			local tileH = math.min(MAX_TILE_SIZE, h - ty)
			do
				local tx = 0
				local _shouldIncrement_1 = false
				while true do
					if _shouldIncrement_1 then
						tx += MAX_TILE_SIZE
					else
						_shouldIncrement_1 = true
					end
					if not (tx < w) then
