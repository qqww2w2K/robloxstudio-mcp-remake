local function manageDatastore(data)
	local RunService = game:GetService("RunService")
	if RunService:IsEdit() then
		return {
			error = "DataStore operations only work in Studio Test/Run mode with API access enabled.",
		}
	end
	local DataStoreService = game:GetService("DataStoreService")
	local action = data.action
	local storeName = data.store_name
	local store = DataStoreService:GetDataStore(storeName)
	local ok, result = pcall(function()
		if action == "get_value" then
			return {
				value = { store:GetAsync(data.key) },
			}
		elseif action == "set_value" then
			store:SetAsync(data.key, data.value)
			return {
				success = true,
			}
		elseif action == "remove_value" then
			store:RemoveAsync(data.key)
			return {
				success = true,
			}
		elseif action == "list_keys" then
			local pages = store:ListKeysAsync(data.prefix)
			local keys = {}
			local count = 0
			while count < 50 do
				local current = pages:GetCurrentPage()
				for _, entry in current do
					local _keyName = entry.KeyName
					table.insert(keys, _keyName)
					count += 1
				end
				if pages.IsFinished then
					break
				end
				pages:AdvanceToNextPageAsync()
			end
			return {
				keys = keys,
			}
		elseif action == "increment_value" then
			local _object = {}
			local _left = "value"
			local _exp = data.key
			local _condition = (data.delta)
			if not (_condition ~= 0 and _condition == _condition and _condition) then
				_condition = 1
			end
			_object[_left] = { store:IncrementAsync(_exp, _condition) }
			return _object
		end
		return {
			error = `Unknown action: {action}`,
		}
	end)
	if not ok then
		return {
			error = tostring(result),
		}
	end
	return result
end
-- === Feature 24: Changelog Tracker ===
local function trackChanges(data)
	local action = data.action
	if action == "start_tracking" then
		Recording.setTracking(true)
		return {
			success = true,
			message = "Tracking started",
		}
	elseif action == "stop_tracking" then
		Recording.setTracking(false)
		return {
			success = true,
			message = "Tracking stopped",
		}
	elseif action == "get_changelog" then
		local changeLog = Recording.getLog()
		local md = "# MCP Changelog\n\n"
		for _, entry in changeLog do
			md ..= `- [{os.date("%X", entry.time)}] **{entry.tool}** - {if entry.success then "Success" else "Failure"}\n`
		end
		return {
			success = true,
			changelog = md,
		}
	elseif action == "clear_changelog" then
		Recording.clearLog()
		return {
			success = true,
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
-- === Feature 25: Backup Manager ===
local function manageBackups(data)
	local action = data.action
	if action == "create_backup" then
		local serialize
		serialize = function(inst)
			local _object = {
				name = inst.Name,
				className = inst.ClassName,
			}
			local _left = "children"
			local _exp = inst:GetChildren()
			-- ▼ ReadonlyArray.map ▼
			local _newValue = table.create(#_exp)
			local _callback = function(c)
				return serialize(c)
			end
			for _k, _v in _exp do
				_newValue[_k] = _callback(_v, _k - 1, _exp)
			end
			-- ▲ ReadonlyArray.map ▲
			_object[_left] = _newValue
			local info = _object
			if inst:IsA("LuaSourceContainer") then
				info.source = inst.Source
			end
			return info
		end
		local backup = {
			timestamp = tick(),
			gameName = game.Name,
			data = serialize(game.Workspace),
		}
		return {
			success = true,
			backupSize = #HttpService:JSONEncode(backup),
			backup = backup,
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
return {
	getAttribute = getAttribute,
	setAttribute = setAttribute,
	getAttributes = getAttributes,
	deleteAttribute = deleteAttribute,
	getTags = getTags,
	addTag = addTag,
	removeTag = removeTag,
	getTagged = getTagged,
	getSelection = getSelection,
	executeLuau = executeLuau,
	undo = undo,
	redo = redo,
	historyControl = historyControl,
	controlSelection = controlSelection,
	manageDatastore = manageDatastore,
	trackChanges = trackChanges,
	manageBackups = manageBackups,
}
