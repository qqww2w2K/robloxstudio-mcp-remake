end
-- === Feature 27: Naming Convention Fixer ===
local function fixNaming(data)
	local action = data.action
	local targetPath = data.target_path
	local root = getInstanceByPath(targetPath)
	if not root then
		return {
			error = "Target path not found",
		}
	end
	local recordingId = beginRecording(`Fix naming: {action}`)
	local toPascal = function(s)
		return (string.gsub((string.gsub(s, "(%a)([%w]*)", function(f, r)
			return string.upper(f) .. string.lower(r)
		end)), "%s+", ""))
	end
	local toSnake = function(s)
		return string.lower((string.gsub(s, "%s+", "_")))
	end
	local ok = pcall(function()
		local all = root:GetDescendants()
		for _, inst in all do
			if action == "rename_to_pascal" then
				inst.Name = toPascal(inst.Name)
			elseif action == "rename_to_snake" then
				inst.Name = toSnake(inst.Name)
