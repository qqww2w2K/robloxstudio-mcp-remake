		local newSource = joinLines(resultLines, hadTrailingNewline)
		ScriptEditorService:UpdateSourceAsync(instance, function()
			return newSource
		end)
		return {
			success = true,
			instancePath = instancePath,
			deletedLines = {
				startLine = startLine,
				endLine = endLine,
			},
			linesDeleted = endLine - startLine + 1,
			newLineCount = #resultLines,
			message = "Script lines deleted successfully",
		}
	end)
	if success then
		finishRecording(recordingId, true)
		return result
	end
	finishRecording(recordingId, false)
	return {
		error = `Failed to delete script lines: {result}`,
	}
end
local function syncProject(data)
	local action = data.action
	if action == "get_scripts" then
		local _condition = (data.instance_path)
		if not (_condition ~= "" and _condition) then
			_condition = "game"
		end
		local startPath = _condition
		local startInst = getInstanceByPath(startPath)
		if not startInst then
			return {
				error = "Start instance not found",
			}
		end
		local scripts = {}
		local function findRecursive(inst)
			if inst:IsA("LuaSourceContainer") then
				local _arg0 = {
					path = getInstancePath(inst),
					source = readScriptSource(inst),
				}
				table.insert(scripts, _arg0)
			end
			for _, child in inst:GetChildren() do
				findRecursive(child)
			end
		end
		findRecursive(startInst)
		return {
			scripts = scripts,
		}
	elseif action == "update_scripts" then
		local updates = (data.updates) or {}
		local count = 0
		for _, update in updates do
			local inst = getInstanceByPath(update.path)
			if inst and inst:IsA("LuaSourceContainer") then
				local ok = pcall(function()
					ScriptEditorService:UpdateSourceAsync(inst, function()
						return update.source
					end)
				end)
				if ok then
					count += 1
				end
			end
		end
		return {
			success = true,
			updatedCount = count,
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
-- === Feature 16: Remote Event Monitor ===
local remoteLogs = {}
local activeListeners = {}
local function monitorRemotes(requestData)
	local action = requestData.action
	if action == "list_remotes" then
		local remotes = {}
		local all = game:GetDescendants()
		for _, obj in all do
			if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
				local _arg0 = {
					path = getInstancePath(obj),
					className = obj.ClassName,
				}
				table.insert(remotes, _arg0)
			end
		end
		return {
			success = true,
			remotes = remotes,
		}
	end
	if action == "log_fires" then
		local remotePath = requestData.remote_path
		local _condition = (requestData.duration_seconds)
		if not (_condition ~= 0 and _condition == _condition and _condition) then
			_condition = 30
		end
		local duration = _condition
		local target = if remotePath ~= "" and remotePath then getInstanceByPath(remotePath) else nil
		local _result
		if target then
			_result = { target }
		else
			local _exp = game:GetDescendants()
			-- ▼ ReadonlyArray.filter ▼
			local _newValue = {}
			local _callback = function(o)
				return o:IsA("RemoteEvent")
			end
			local _length = 0
			for _k, _v in _exp do
				if _callback(_v, _k - 1, _exp) == true then
					_length += 1
					_newValue[_length] = _v
				end
			end
			-- ▲ ReadonlyArray.filter ▲
			_result = _newValue
		end
		local targets = _result
		for _, obj in targets do
			if obj:IsA("RemoteEvent") and not (activeListeners[obj] ~= nil) then
				local conn = obj.OnServerEvent:Connect(function(player, ...)
					local args = { ... }
					local _arg0 = {
						remote = getInstancePath(obj),
						type = "OnServerEvent",
						args = HttpService:JSONEncode(args),
						time = tick(),
					}
					table.insert(remoteLogs, _arg0)
				end)
				activeListeners[obj] = conn
			end
		end
		task.delay(duration, function()
			for obj, conn in activeListeners do
				conn:Disconnect()
			end
			table.clear(activeListeners)
		end)
		return {
			success = true,
			message = `Logging started for {duration}s`,
		}
	end
	if action == "get_logs" then
		return {
			success = true,
			logs = remoteLogs,
		}
	end
	if action == "stop_logging" then
		for obj, conn in activeListeners do
			conn:Disconnect()
		end
		table.clear(activeListeners)
		return {
			success = true,
			message = "Logging stopped",
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
-- === Feature 17: Script Dependency Mapper ===
local function mapDependencies(requestData)
	local action = requestData.action
	local scriptPath = requestData.script_path
	if action == "get_dependencies" then
		local instance = getInstanceByPath(scriptPath)
		if not instance or not instance:IsA("LuaSourceContainer") then
			return {
				error = "Invalid script path",
			}
		end
		local source = readScriptSource(instance)
		local deps = {}
		-- Simple regex-like scan for require(path)
		for match in string.gmatch(source, "require%s*%(%s*([^%)]+)%s*%)") do
			table.insert(deps, match)
		end
		return {
			success = true,
			dependencies = deps,
		}
	end
	if action == "find_circular" then
		return {
			success = true,
			circular = {},
			note = "Full graph analysis not implemented",
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
-- === Feature 18: Variable Leak Finder ===
local function findVariableLeaks(requestData)
	local action = requestData.action
	local scriptPath = requestData.script_path
	local scan = function(inst)
		local source = readScriptSource(inst)
		local lines = splitLines(source)
		local leaks = {}
		-- ▼ ReadonlyArray.forEach ▼
		local _callback = function(line, i)
			local match1 = string.match(line, "^%s*([%a_][%w_]*)%s*=")
			local match2 = string.match(line, "^%s*(local)%s")
			local _condition = match1
			if _condition ~= 0 and _condition == _condition and _condition ~= "" and _condition then
				_condition = not (match2 ~= 0 and match2 == match2 and match2 ~= "" and match2)
			end
			if _condition ~= 0 and _condition == _condition and _condition ~= "" and _condition then
				local _arg0 = {
					line = i + 1,
					content = (string.gsub((string.gsub(line, "^%s+", "")), "%s+$", "")),
				}
				table.insert(leaks, _arg0)
			end
		end
		for _k, _v in lines do
			_callback(_v, _k - 1, lines)
		end
		-- ▲ ReadonlyArray.forEach ▲
		return leaks
	end
	if action == "scan_script" then
		local instance = getInstanceByPath(scriptPath)
		if not instance or not instance:IsA("LuaSourceContainer") then
			return {
				error = "Invalid script path",
			}
		end
		return {
			success = true,
			leaks = scan(instance),
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
-- === Feature 19: Anti-Cheat Scanner ===
local function scanAnticheat(requestData)
	local action = requestData.action
	local _condition = (requestData.target_path)
	if not (_condition ~= "" and _condition) then
		_condition = "game"
	end
	local targetPath = _condition
	if action == "scan_suspicious" then
		local root = getInstanceByPath(targetPath)
		if not root then
			return {
				error = "Target path not found",
			}
		end
		local results = {}
		local all = root:GetDescendants()
		local scripts = {}
		for _, o in all do
			if o:IsA("LuaSourceContainer") then
				table.insert(scripts, o)
			end
		end
		local suspicious = { "loadstring", "getfenv", "setfenv", "rawget", "rawset", "HttpService:GetAsync" }
		for _, s in scripts do
			local source = readScriptSource(s)
			local findings = {}
			for _1, pattern in suspicious do
				if (string.find(source, pattern)) ~= nil then
					table.insert(findings, pattern)
				end
			end
			if #findings > 0 then
				local _arg0 = {
					path = getInstancePath(s),
					findings = findings,
				}
				table.insert(results, _arg0)
			end
		end
		return {
			success = true,
			results = results,
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
-- === Feature 26: Comment Inserter ===
local function insertComments(requestData)
	local action = requestData.action
	local scriptPath = requestData.script_path
	local _condition = (requestData.author_name)
	if not (_condition ~= "" and _condition) then
		_condition = "Gemini MCP"
	end
	local author = _condition
	local instance = getInstanceByPath(scriptPath)
	if not instance or not instance:IsA("LuaSourceContainer") then
		return {
			error = "Invalid script path",
		}
	end
	local source = readScriptSource(instance)
	if action == "comment_script" then
		local header = `--[[\n\tDescription: Auto-generated header\n\tAuthor: {author}\n\tDate: {os.date("%x")}\n--]]\n\n`
		local newSource = header .. source
		local ok = pcall(function()
			ScriptEditorService:UpdateSourceAsync(instance, function()
				return newSource
			end)
		end)
		if not ok then
			instance.Source = newSource
		end
		return {
			success = true,
			message = "Header added",
		}
	end
	if action == "remove_comments" then
		local lines = splitLines(source)
		local newLines = {}
		for _, l in lines do
			if not { string.match(l, "^%s*%-%-") } then
				table.insert(newLines, l)
			end
		end
		local newSource = table.concat(newLines, "\n")
		local ok = pcall(function()
			ScriptEditorService:UpdateSourceAsync(instance, function()
				return newSource
			end)
		end)
		if not ok then
			instance.Source = newSource
		end
		return {
			success = true,
			message = "Comments removed",
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
return {
	getScriptSource = getScriptSource,
	setScriptSource = setScriptSource,
	editScriptLines = editScriptLines,
	insertScriptLines = insertScriptLines,
	deleteScriptLines = deleteScriptLines,
	syncProject = syncProject,
	monitorRemotes = monitorRemotes,
	mapDependencies = mapDependencies,
	findVariableLeaks = findVariableLeaks,
	scanAnticheat = scanAnticheat,
	insertComments = insertComments,
}
]]></string>
