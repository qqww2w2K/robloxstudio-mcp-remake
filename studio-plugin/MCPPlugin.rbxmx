local MAX_TILE_SIZE = 1024
local BASE64_CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
local function encodeBase64(buf)
	local len = buffer.len(buf)
