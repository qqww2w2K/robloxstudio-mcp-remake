	if action == "create_lod_variants" then
		local high = mesh:Clone()
		high.Name = mesh.Name .. "_LOD0"
		high.Parent = mesh.Parent
		local low = mesh:Clone()
		low.Name = mesh.Name .. "_LOD1"
		low.RenderFidelity = Enum.RenderFidelity.Precise
