				local camera = game.Workspace.CurrentCamera
				if camera then
					local _position = inst.Position
					local _vector3 = Vector3.new(0, 10, 10)
					camera.CFrame = CFrame.new(_position + _vector3, inst.Position)
				end
			elseif inst and inst:IsA("Model") then
				local camera = game.Workspace.CurrentCamera
				if camera then
					local cf, size = inst:GetBoundingBox()
