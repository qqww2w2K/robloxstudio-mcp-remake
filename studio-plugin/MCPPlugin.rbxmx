			Selection:Set({ instance })
			local result = captureScreenshot()
			Selection:Set(oldSelection)
			return result
		end
	end
	return captureScreenshot()
end
return {
	captureScreenshot = captureScreenshot,
	captureViewport = captureViewport,
}
