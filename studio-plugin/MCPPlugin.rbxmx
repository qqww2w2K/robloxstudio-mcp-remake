local function controlLighting(data)
	local Lighting = game:GetService("Lighting")
	local action = data.action
	if action == "get_state" then
		return {
			Brightness = Lighting.Brightness,
			ClockTime = Lighting.ClockTime,
			FogColor = {
				R = Lighting.FogColor.R,
				G = Lighting.FogColor.G,
				B = Lighting.FogColor.B,
			},
			FogEnd = Lighting.FogEnd,
			Ambient = {
				R = Lighting.Ambient.R,
				G = Lighting.Ambient.G,
				B = Lighting.Ambient.B,
			},
		}
	elseif action == "set_property" then
		local prop = data.property
		local val = data.value
		local ok, err = pcall(function()
			local converted = convertPropertyValue(Lighting, prop, val)
			Lighting[prop] = if converted ~= nil then converted else val
		end)
		if not ok then
			return {
				error = tostring(err),
			}
		end
		return {
			success = true,
		}
	elseif action == "set_atmosphere" then
		local atmosphere = Lighting:FindFirstChildWhichIsA("Atmosphere") or Instance.new("Atmosphere", Lighting)
		local prop = data.property
		local val = data.value
		local ok, err = pcall(function()
			local converted = convertPropertyValue(atmosphere, prop, val)
			atmosphere[prop] = if converted ~= nil then converted else val
		end)
		if not ok then
			return {
				error = tostring(err),
			}
		end
		return {
			success = true,
		}
	elseif action == "apply_preset" then
		local preset = data.preset
		if preset == "sunset" then
			Lighting.ClockTime = 18
			Lighting.Brightness = 2
		elseif preset == "midnight" then
			Lighting.ClockTime = 0
			Lighting.Brightness = 0
		elseif preset == "noon" then
			Lighting.ClockTime = 12
			Lighting.Brightness = 3
		elseif preset == "space" then
			Lighting.ClockTime = 0
			Lighting.Ambient = Color3.new(0, 0, 0)
			local sky = Lighting:FindFirstChildWhichIsA("Sky") or Instance.new("Sky", Lighting)
			sky.StarCount = 5000
		end
		return {
			success = true,
			preset = preset,
		}
	end
	return {
		error = `Unknown action: {action}`,
	}
end
