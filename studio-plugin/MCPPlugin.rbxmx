end
-- === Feature 29: LOD Generator ===
local function generateLod(data)
	local action = data.action
	local meshPath = data.mesh_path
	local mesh = getInstanceByPath(meshPath)
	if not mesh or not mesh:IsA("MeshPart") then
		return {
			error = "MeshPart not found",
